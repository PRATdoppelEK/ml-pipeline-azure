# Azure & Environment Secrets
# Crucial for protecting service principals and ACR credentials
.env
.env.*
.azure/
azure_credentials.json

# Model Artifacts & Experiments
# Logged runs and serialized models should not be in version control
models/
experiments/runs.jsonl
*.pkl
*.joblib
*.model

# Data & Ingestion
# Data from REST API, SQL, or CSV ingestion should remain local
data/*.csv
data/*.parquet
data/*.sql
data/*.json

# Testing & Coverage
# Generated by pytest and flake8 during CI/CD[cite: 16]
.pytest_cache/
.coverage
htmlcov/
*.log

# Docker
# Local build artifacts
.docker/

# Python & Dependencies
# Based on your production tech stack[cite: 16]
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# IDE & OS
.vscode/
.idea/
.DS_Store
Thumbs.db
